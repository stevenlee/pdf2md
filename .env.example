LLM_PROVIDER=ollama

# Ollama (OpenAI Compatible) API 設定
OLLAMA_API_BASE=http://192.168.1.103:11434/v1
#
# === 模型自由選用 ===
# 每個角色都可指向任一台遠端 Ollama 已安裝的模型；註解掉則使用 config.py 預設。
# 遠端目前可用 (ollama list)：
#   文字/邏輯 : qwen3.6:latest, gpt-oss:120b, nemotron-3-super:120b
#   視覺/圖表 : gemma4:latest, gemma4:e4b, gemma4:26b, gemma4:31b, llava:13b
#   OCR      : glm-ocr:latest
#   嵌入      : nomic-embed-text:latest
#
# OLLAMA_MODEL_TEXT=qwen3.6:latest      # 文字與邏輯 (純文字任務)
OLLAMA_MODEL_VISION=gemma4:26b          # 複雜圖表解析 (純 Mermaid 任務 / 降級用)
# OLLAMA_MODEL_OCR=glm-ocr:latest       # OCR 文字提取 / DIAGRAM 失敗降級
# OLLAMA_MODEL_SMART=gemma4:26b         # 單次「分類+轉換」合併呼叫 (預設=gemma4:26b，準)
                                        # 圖表簡單/趕時間可改 gemma4:e4b (約 4× 速度，但複雜圖會遺漏節點)

# Vision/OCR 穩定性設定
VISION_MAX_CONCURRENCY=2
VISION_REQUEST_TIMEOUT=600
VISION_REQUEST_RETRIES=2

# 其他選用設定 (暫不使用)
VLLM_API_BASE=http://192.168.1.103:9000/v1
VLLM_MODEL=openai/gpt-oss-20b
VLLM_API_KEY=dummy-token

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Remote DGX server location:
REMOTE_USER=[USER NAME]
REMOTE_HOST=[IP_ADDRESS]
REMOTE_DIR=~/pdf2md

# 目錄管理 (Obsidian Vault 結構)
INPUT_DIR=pdf2mdVault/input_dir
OUTPUT_DIR=pdf2mdVault/output_dir
