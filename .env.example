LLM_PROVIDER=ollama

# Ollama (OpenAI Compatible) API 設定
OLLAMA_API_BASE=http://192.168.1.103:11434/v1
# OLLAMA_MODEL_TEXT=qwen3.6:latest     # Qwen 負責文字與邏輯
OLLAMA_MODEL_VISION=gemma4:26b       # Gemma 26b 負責複雜圖表解析
# OLLAMA_MODEL_OCR=glm-ocr:latest      # GLM 專精 OCR 提取

# Vision/OCR 穩定性設定
VISION_MAX_CONCURRENCY=2
VISION_REQUEST_TIMEOUT=180
VISION_REQUEST_RETRIES=2

# 其他選用設定 (暫不使用)
VLLM_API_BASE=http://192.168.1.103:9000/v1
VLLM_MODEL=openai/gpt-oss-20b
VLLM_API_KEY=dummy-token

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Remote DGX server location:
REMOTE_USER=[USER NAME]
REMOTE_HOST=[IP_ADDRESS]
REMOTE_DIR=~/pdf2md

# 目錄管理 (Obsidian Vault 結構)
INPUT_DIR=pdf2mdVault/input_dir
OUTPUT_DIR=pdf2mdVault/output_dir
